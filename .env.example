# Runtime mode: replay, mock, or live
SENTINEL_MODE=replay
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
CORS_ORIGIN=
SESSION_COOKIE_SECURE=false

# TxLINE credentials are optional for replay/mock mode. Never commit real values.
TXLINE_NETWORK=devnet
TXLINE_API_ORIGIN=https://txline-dev.txodds.com
TXLINE_GUEST_JWT=
TXLINE_API_TOKEN=

# Optional: enabled only when both variables are set and TELEGRAM_ENABLED=true.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=

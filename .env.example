# The decision engine stays in deterministic replay. The official TxLINE
# devnet transport is a process-wide, read-only sidecar enabled separately.
SENTINEL_MODE=replay
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
CORS_ORIGIN=
SESSION_COOKIE_SECURE=false

# Official TxLINE devnet transport. Replay needs none of these credentials.
# Put real values only in an ignored mode-0600 local file or a deployment
# secret store. Never put a wallet/keypair in the runtime environment.
TXLINE_NETWORK=devnet
TXLINE_API_ORIGIN=https://txline-dev.txodds.com
TXLINE_GUEST_JWT=
TXLINE_API_TOKEN=
TXLINE_LIVE_ENABLED=false

# Optional: enabled only when both variables are set and TELEGRAM_ENABLED=true.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=

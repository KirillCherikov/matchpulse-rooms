{
  "name": "txline-sentinel",
  "version": "0.1.0",
  "private": true,
  "description": "Explainable real-time sports market intelligence designed for TxLINE.",
  "type": "module",
  "engines": {
    "node": ">=22.13.0",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "concurrently -k \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx watch src/server.ts",
    "dev:web": "vite --host 0.0.0.0",
    "start": "node dist/server.js",
    "build": "npm run build:web && tsc -p tsconfig.server.json",
    "build:web": "vite build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.web.json --noEmit && tsc -p tsconfig.tests.json --noEmit && tsc -p tsconfig.scripts.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "cli": "tsx src/cli.ts",
    "txline:devnet": "tsx scripts/txline-devnet.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/static": "^9.3.0",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.1",
    "@solana/web3.js": "1.98.4",
    "commander": "^13.1.0",
    "dotenv": "^16.6.1",
    "fastify": "^5.4.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@coral-xyz/anchor": "0.32.1",
    "@eslint/js": "^9.30.1",
    "@playwright/test": "^1.54.1",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/eslint-plugin": "^8.36.0",
    "@typescript-eslint/parser": "^8.36.0",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.2.0",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.3",
    "tweetnacl": "1.0.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.36.0",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "uuid": "11.1.1",
    "rpc-websockets": {
      "uuid": "14.0.1"
    }
  }
}
